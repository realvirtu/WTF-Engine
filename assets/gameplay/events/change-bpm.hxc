import funkin.play.song.SongEvent;
import funkin.Conductor;

class ChangeBPMEvent extends SongEvent
{
    public function new()
    {
        super("change-bpm");
    }

    override function handle(value:Dynamic)
    {
        super.handle(value);

        var conductor:Conductor = Conductor.instance;
        var bpm:Float = getFloat("b");

        conductor.bpm = bpm;
    }
}