package funkin.modding.event;

/**
 * An enum of the different script event types.
 */
enum ScriptEventType
{
	// Basic
	CREATE;
	UPDATE;
	DESTROY;

	// State
	STATE_CREATE;
	SUBSTATE_OPEN;
	SUBSTATE_CLOSE;

	// Note
	NOTE_HIT;
	NOTE_MISS;
	HOLD_NOTE_HOLD;
	HOLD_NOTE_DROP;
	GHOST_MISS;

	// Conductor
	STEP_HIT;
	BEAT_HIT;

	// PlayState
	SONG_LOAD;
	SONG_START;
	SONG_END;
	SONG_RETRY;
	SONG_EVENT;
	COUNTDOWN_START;
	COUNTDOWN_STEP;
	PAUSE;
	RESUME;
	GAMEOVER_START;
	GAMEOVER_LOOP;
	GAMEOVER_RETRY;

	// Freeplay
	FREEPLAY_ENTER;
	FREEPLAY_EXIT;
	FREEPLAY_INTRO;
	FREEPLAY_OUTRO;
	FREEPLAY_INTRO_DONE;
	FREEPLAY_OUTRO_DONE;
	FREEPLAY_SONG_SELECTED;
	FREEPLAY_SONG_FAVORITED;
}
